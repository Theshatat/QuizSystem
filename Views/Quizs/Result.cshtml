@model QuizAttempt

@{
    ViewData["Title"] = "Quiz Results";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <!-- Result Card -->
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">
                        <i class="bi bi-award-fill"></i> Results for @Model.Quiz.Title
                    </h3>
                </div>

                <div class="card-body text-center">
                    <!-- Score Section -->
                    <h1 class="fw-bold display-4 text-success">
                        @Model.Score / @Model.Quiz.Questions.Count
                    </h1>
                    <p class="text-muted">Correct Answers</p>

                    <!-- Time Info -->
                    <hr />
                    <div class="row">
                        <div class="col-md-6">
                            <p class="fw-bold mb-1"><i class="bi bi-play-fill text-success"></i> Started At</p>
                            <p class="text-muted">@Model.StaretedAt.ToString("f")</p>
                        </div>
                        <div class="col-md-6">
                            <p class="fw-bold mb-1"><i class="bi bi-stop-fill text-danger"></i> Finished At</p>
                            <p class="text-muted">@Model.FinishedAt.ToString("f")</p>
                        </div>
                    </div>

                    <!-- Duration -->
                    <div class="mt-3">
                        <p class="fw-bold mb-1"><i class="bi bi-hourglass-split text-warning"></i> Time Spent</p>
                        <p class="text-muted">
                            @{
                                var duration = Model.FinishedAt - Model.StaretedAt;
                                <span>@duration.Minutes min @duration.Seconds sec</span>
                                ;
                            }
                        </p>
                    </div>

                    <!-- Badge for Pass/Fail -->
                    <div class="mt-4">
                        @if (Model.Score >= (Model.Quiz.Questions.Count / 2))
                        {
                            <span class="badge bg-success fs-5 p-2">
                                <i class="bi bi-check-circle-fill"></i> Passed
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-5 p-2">
                                <i class="bi bi-x-circle-fill"></i> Failed
                            </span>
                        }
                    </div>
                </div>

                <!-- Footer -->
                <div class="card-footer text-center bg-light">
                    <a asp-controller="Quizs" asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-arrow-left-circle"></i> Back to Quizzes
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
