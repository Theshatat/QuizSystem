@model IEnumerable<QuizSystem.Models.Quiz>

@{
    ViewData["Title"] = "All Quizess";
}

<h1>@ViewData["Title"]</h1>

<div class="container mt-4">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">@item.Title</h5>
                        <p class="card-text text-muted">@item.Description</p>
                        <p><strong>Published:</strong> @(item.IsPublished ? "Yes" : "No")</p>
                        <p><strong>Created:</strong> @item.CreatedAt.ToShortDateString()</p>
                        <p><strong>Duration:</strong> @item.DurationInMinutes minutes</p>
                    </div>
                    <div class="card-footer d-flex justify-content-between">
                        <div>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            }
                        </div>
                        <a asp-action="TakeQuiz" asp-route-id="@item.Id" class="btn btn-sm btn-success">Take Quiz</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    </p>
}
