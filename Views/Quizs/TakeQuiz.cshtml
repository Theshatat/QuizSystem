@model Quiz

@{
    ViewData["Title"] = "Take Quiz - " + Model.Title;
}

<div class="container mt-4">
    <div class="text-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="bi bi-pencil-square"></i> @Model.Title
        </h2>
        <p class="text-muted">@Model.Description</p>
    </div>
    <!-- Timer -->
    <div class="row mb-4">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow-sm border-0 text-center">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-primary">
                        <i class="bi bi-alarm"></i> Time Remaining
                    </h5>
                    <h3 id="timer" class="fw-bold text-danger"></h3>
                    @* <div class="progress" style="height: 20px;">
                        <div id="timerBar"
                             class="progress-bar bg-success"
                             role="progressbar"
                             style="width: 100%;">
                        </div>
                    </div> *@
                </div>
            </div>
        </div>
    </div>


    <form asp-action="SubmitQuiz" method="post" id="quizForm">
        <input type="hidden" name="QuizId" value="@Model.Id" />
        <input type="hidden" name="AttemptId" value="@ViewBag.AttemptId" />

        @for (int i = 0; i < Model.Questions.Count; i++)
        {
            var question = Model.Questions.ElementAt(i);

            <div class="card shadow-sm mb-4 border-primary">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="bi bi-question-circle-fill"></i>
                    Question @(i + 1)
                </div>
                <div class="card-body">
                    <p class="fw-bold fs-5">@question.Text</p>

                    @foreach (var answer in question.Answers)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input"
                                   type="radio"
                                   name="Answers[@question.Id]"
                                   value="@answer.Id"
                                   id="answer_@answer.Id" />

                            <label class="form-check-label" for="answer_@answer.Id">
                                <i class="bi bi-check-circle text-success"></i> @answer.Text
                            </label>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="text-center">
            <button type="submit" class="btn btn-lg btn-success px-4">
                <i class="bi bi-send-fill"></i> Submit Quiz
            </button>
        </div>
    </form>
</div>

<script>
    var minutes = @Model.DurationInMinutes; // quiz duration from backend
    var seconds = minutes * 60;

    var timer = setInterval(function () {
        var min = Math.floor(seconds / 60);
        var sec = seconds % 60;

        document.getElementById("timer").innerText =
            min + "m " + sec + "s ";

        seconds--;

        if (seconds < 0) {
            clearInterval(timer);
            document.getElementById("quizForm").submit(); // auto-submit when time is up
        }
    }, 1000);
</script>